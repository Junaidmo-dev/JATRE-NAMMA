<resources>
    <style name="Theme.JatreNammaPride" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#FF9933</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#FFFBF2</item>
        <!-- Use the app icon for the splash screen (adjust as needed) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Post-splash screen theme -->
        <item name="postSplashScreenTheme">@style/Theme.JatreNammaPride</item>
    </style>
</resources>
